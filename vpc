#######Get Region Details of AWS CLI#########

curl http://169.254.169.254/latest/dynamic/instance-identity/document | grep region



########Enable VPC Flow Logs to S3 Bucket########

aws s3api create-bucket --bucket flowlog1234 --region <region> --create-bucket-configuration LocationConstraint=<region>


#### Get VPC ID to Generate Flow Log of VPC########

aws ec2 describe-vpcs --query 'Vpcs[*].[VpcId,Tags[?Key==`Name`].Value,CidrBlock]' --filters "Name=tag:Name,Values='VPC1'"

####Enable Flow Log to Bucket######

aws ec2 create-flow-logs --resource-type VPC --resource-ids <vpc-id> --traffic-type ALL --log-destination-type s3 --log-destination arn:aws:s3:::<flowlog####>

#### Confirm Flow Log is Created####

aws ec2 describe-flow-logs




